{
  "name": "bbb-ics-generator",
  "version": "1.0.0",
  "main": "src/server.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node src/server.js",
    "update": "node src/cronUpdate.js",
    "generate-html": "node src/generateHTML.js",
    "test": "node --test 'tests/e2e/*.test.js'",
    "test:watch": "node --watch --test 'tests/e2e/*.test.js'",
    "test:a11y": "playwright test --project=chromium-a11y",
    "test:a11y:report": "playwright show-report",
    "test:ui": "playwright test --project=chromium-ui",
    "test:ui:report": "PLAYWRIGHT_JSON_OUTPUT_NAME=test-results.json playwright test --project=chromium-ui --reporter=json,html && node scripts/analyze-report.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "express": "^4.21.2",
    "ics": "^3.8.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1"
  }
}
